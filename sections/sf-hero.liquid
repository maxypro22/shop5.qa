{%- comment -%}
  SHOP FIVE — Premium hero
  Designed gradient artwork by default; merchants can swap in a photo.
{%- endcomment -%}

<section class="sf-hero-section" data-section-id="{{ section.id }}" data-section-type="sf-hero">
  <div class="sf-hero {% if section.settings.image %}sf-hero--photo{% endif %}">
      {%- if section.settings.image -%}
        {{- section.settings.image | image_url: width: 2400 | image_tag:
              fetchpriority: 'high',
              widths: '600,900,1200,1600,2000,2400',
              sizes: '(max-width: 1279px) 100vw, 1248px',
              class: 'sf-hero__image',
              alt: section.settings.image.alt | default: section.settings.title -}}
        <span class="sf-hero__scrim" aria-hidden="true"></span>
      {%- endif -%}

      <div class="sf-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="sf-hero__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="sf-hero__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="sf-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}

        <div class="sf-hero__actions">
          {%- if section.settings.button_text != blank -%}
            <a href="{{ section.settings.button_link | default: routes.collections_url }}" class="sf-hero__button sf-hero__button--primary">{{ section.settings.button_text | escape }}</a>
          {%- endif -%}

          {%- if section.settings.button_2_text != blank and section.settings.button_2_link != blank -%}
            <a href="{{ section.settings.button_2_link }}" class="sf-hero__button sf-hero__button--ghost">{{ section.settings.button_2_text | escape }}</a>
          {%- endif -%}
        </div>

        {%- assign has_highlights = false -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}{%- assign has_highlights = true -%}{%- endif -%}
        {%- endfor -%}

        {%- if has_highlights -%}
          <ul class="sf-hero__highlights" role="list">
            {%- for block in section.blocks -%}
              {%- if block.settings.text != blank -%}
                <li class="sf-hero__highlight" {{ block.shopify_attributes }}>
                  <span class="sf-hero__highlight-dot" aria-hidden="true"></span>
                  {{- block.settings.text | escape -}}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
  </div>
</section>

<style>
  .sf-hero {
    position: relative;
    overflow: hidden;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: #0e0c33;
    background-image: url('{{ 'sf-hero-bg.svg' | asset_url }}');
    background-size: cover;
    background-position: center;
  }

  .sf-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sf-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(11, 10, 38, 0.72), rgba(11, 10, 38, 0.28));
  }

  .sf-hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    padding: 64px 24px;
  }

  .sf-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #c3c0ff;
    background: rgba(79, 70, 229, 0.25);
    border: 1px solid rgba(139, 128, 255, 0.45);
    border-radius: 999px;
    padding: 6px 16px;
    margin-bottom: 20px;
  }

  .sf-hero__title {
    color: #ffffff;
    font-size: clamp(30px, 4.6vw, 48px);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 14px;
  }

  .sf-hero__subtitle {
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(14px, 1.6vw, 17px);
    line-height: 1.65;
    margin: 0 auto 28px;
    max-width: 540px;
  }

  .sf-hero__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .sf-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 16px 40px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .sf-hero__button--primary {
    background: #4f46e5;
    color: #ffffff;
    box-shadow: 0 8px 24px rgba(79, 70, 229, 0.40);
  }

  .sf-hero__button--primary:hover {
    background: #3525cd;
    transform: translateY(-2px);
  }

  .sf-hero__button--ghost {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.35);
  }

  .sf-hero__button--ghost:hover {
    border-color: #ffffff;
    background: rgba(255, 255, 255, 0.16);
    transform: translateY(-2px);
  }

  .sf-hero__button:active {
    transform: scale(0.98);
  }

  .sf-hero__highlights {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px 26px;
    list-style: none;
    margin: 30px 0 0;
    padding: 0;
  }

  .sf-hero__highlight {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 13px;
    font-weight: 500;
  }

  .sf-hero__highlight-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #8b80ff;
    animation: sf-hero-pulse 2s ease-in-out infinite;
  }

  @keyframes sf-hero-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  @media screen and (max-width: 640px) {
    .sf-hero {
      min-height: 440px;
    }

    .sf-hero__content {
      padding: 44px 18px;
    }

    .sf-hero__button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sf-hero__highlight-dot {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "SF Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Optional — a designed brand background is used when empty."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "شوب فايف — قطر"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "كل ما تحتاجه في مكان واحد"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "تسوق أحدث المنتجات من الأزياء والساعات والعطور والإكسسوارات مع توصيل سريع لجميع مناطق قطر"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary button text",
      "default": "تسوق الآن"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary button text"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "توصيل خلال ٤ ساعات في الدوحة"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "SF Hero",
      "blocks": [
        { "type": "highlight" }
      ]
    }
  ]
}
{% endschema %}
