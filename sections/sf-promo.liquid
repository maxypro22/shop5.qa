{%- comment -%}
  SHOP FIVE — App download promo banner
  Flat indigo banner, giant decorative glyph, black store buttons (mockup style).
{%- endcomment -%}

<section class="sf-promo" data-section-id="{{ section.id }}" data-section-type="sf-promo">
  <div class="sf-promo__banner">
    <svg class="sf-promo__glyph" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M16 1H8C6.34 1 5 2.34 5 4v16c0 1.66 1.34 3 3 3h8c1.66 0 3-1.34 3-3V4c0-1.66-1.34-3-3-3zm1 17H7V4h10v14zm-5 4c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
    </svg>

    <div class="container">
      <div class="sf-promo__content">
        <img class="sf-promo__logo" src="{{ 'shop5-logo.png' | asset_url }}" width="160" height="160" loading="lazy" decoding="async" alt="{{ shop.name | escape }}">

        <div class="sf-promo__text">
          {%- if section.settings.title != blank -%}
            <h2 class="sf-promo__title">{{ section.settings.title | escape }}</h2>
          {%- endif -%}

          {%- if section.settings.subtitle != blank -%}
            <p class="sf-promo__subtitle">{{ section.settings.subtitle | escape }}</p>
          {%- endif -%}
        </div>

        <div class="sf-promo__badges">
          {%- if section.settings.appstore_url != blank -%}
            <a href="{{ section.settings.appstore_url }}" target="_blank" rel="noopener" class="sf-promo__store-button">
              <svg class="sf-promo__store-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <span class="sf-promo__store-text">
                <small>{{ section.settings.appstore_label | default: 'تحميل من' }}</small>
                <strong>App Store</strong>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.play_url != blank -%}
            <a href="{{ section.settings.play_url }}" target="_blank" rel="noopener" class="sf-promo__store-button">
              <svg class="sf-promo__store-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.25-.84-.76-.84-1.35m13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27m3.35-4.31c.34.27.59.69.59 1.19s-.22.9-.57 1.18l-2.29 1.32-2.5-2.5 2.5-2.5 2.27 1.31M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/>
              </svg>
              <span class="sf-promo__store-text">
                <small>{{ section.settings.play_label | default: 'متوفر على' }}</small>
                <strong>Google Play</strong>
              </span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sf-promo__banner {
    position: relative;
    overflow: hidden;
    background: #4f46e5;
    padding: 56px 0;
  }

  .sf-promo__glyph {
    position: absolute;
    width: 320px;
    height: 320px;
    inset-inline-end: -60px;
    top: 50%;
    transform: translateY(-50%) rotate(-12deg);
    color: rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }

  .sf-promo__content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .sf-promo__logo {
    width: 76px;
    height: 76px;
    border-radius: 18px;
    flex: 0 0 auto;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  }

  .sf-promo__text {
    flex: 1 1 auto;
  }

  .sf-promo__title {
    color: #ffffff;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    margin: 0 0 6px;
  }

  .sf-promo__subtitle {
    color: rgba(255, 255, 255, 0.8);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    max-width: 520px;
  }

  .sf-promo__badges {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 0 0 auto;
  }

  .sf-promo__store-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #000000;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    padding: 10px 22px;
    text-decoration: none;
    transition: transform 0.25s ease, background-color 0.25s ease;
  }

  .sf-promo__store-button:hover {
    transform: translateY(-3px);
    background: #191c1d;
  }

  .sf-promo__store-button:active {
    transform: scale(0.97);
  }

  .sf-promo__store-icon {
    width: 28px;
    height: 28px;
    flex: 0 0 auto;
  }

  .sf-promo__store-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    text-align: start;
  }

  .sf-promo__store-text small {
    font-size: 11px;
    opacity: 0.75;
  }

  .sf-promo__store-text strong {
    font-size: 16px;
    font-weight: 700;
  }

  @media screen and (max-width: 860px) {
    .sf-promo__banner {
      padding: 40px 0;
    }

    .sf-promo__content {
      flex-direction: column;
      text-align: center;
      gap: 18px;
    }

    .sf-promo__badges {
      flex-wrap: wrap;
      justify-content: center;
    }

    .sf-promo__glyph {
      width: 220px;
      height: 220px;
      top: auto;
      bottom: -70px;
      transform: rotate(-12deg);
    }
  }
</style>

{% schema %}
{
  "name": "SF App Banner",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "حمّل تطبيق شوب فايف"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "تسوق أسرع وتابع طلباتك واستلم إشعارات العروض الحصرية من جوالك"
    },
    {
      "type": "url",
      "id": "appstore_url",
      "label": "App Store link"
    },
    {
      "type": "text",
      "id": "appstore_label",
      "label": "App Store small label",
      "default": "تحميل من"
    },
    {
      "type": "url",
      "id": "play_url",
      "label": "Google Play link"
    },
    {
      "type": "text",
      "id": "play_label",
      "label": "Google Play small label",
      "default": "متوفر على"
    }
  ],
  "presets": [
    {
      "name": "SF App Banner"
    }
  ]
}
{% endschema %}
